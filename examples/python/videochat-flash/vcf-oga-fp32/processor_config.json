{
  "processor": {
    "name": "internvideo2_image_processor",
    "transforms": [
      {
        "operation": {
          "name": "decode_image",
          "type": "DecodeImage",
          "attrs": {
            "color_space": "RGB"
          }
        }
      },
      {
        "operation": {
          "name": "convert_to_rgb",
          "type": "ConvertRGB"
        }
      },
      {
        "operation": {
          "name": "resize",
          "type": "Resize",
          "attrs": {
            "width": 224,
            "height": 224
          }
        }
      },
      {
        "operation": {
          "name": "rescale",
          "type": "Rescale",
          "attrs": {
            "rescale_factor": 0.00392156862745098
          }
        }
      },
      {
        "operation": {
          "name": "normalize",
          "type": "Normalize",
          "attrs": {
            "mean": [0.485, 0.456, 0.406],
            "std": [0.229, 0.224, 0.225]
          }
        }
      }
    ]
  }
}
