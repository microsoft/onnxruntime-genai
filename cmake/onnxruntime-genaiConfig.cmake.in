@PACKAGE_INIT@

# CMake package configuration for onnxruntime-genai.
#
# This lets SDK layers (python, java, C++ consumers) be built incrementally against a
# prebuilt core via find_package(onnxruntime-genai), instead of rebuilding the whole core.
#
# Provides:
#   - imported target: onnxruntime-genai::onnxruntime-genai (and ::onnxruntime-genai-cuda when built with CUDA)
#   - version:         onnxruntime-genai_VERSION
#   - EP flavor flags:  onnxruntime-genai_USE_CUDA / _USE_TRT_RTX / _USE_DML / _USE_WINML /
#                       _USE_ROCM / _USE_GUIDANCE (0/1) so consumers can pick package names.

set(onnxruntime-genai_VERSION "@VERSION_INFO@")

# Execution-provider flavor of this prebuilt core (mirrors the numeric USE_* compile macros).
set(onnxruntime-genai_USE_CUDA @_genai_export_use_cuda@)
set(onnxruntime-genai_USE_TRT_RTX @_genai_export_use_trt_rtx@)
set(onnxruntime-genai_USE_DML @_genai_export_use_dml@)
set(onnxruntime-genai_USE_WINML @_genai_export_use_winml@)
set(onnxruntime-genai_USE_ROCM @_genai_export_use_rocm@)
set(onnxruntime-genai_USE_GUIDANCE @_genai_export_use_guidance@)

include(CMakeFindDependencyMacro)
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/onnxruntime-genai-targets.cmake")

check_required_components(onnxruntime-genai)
