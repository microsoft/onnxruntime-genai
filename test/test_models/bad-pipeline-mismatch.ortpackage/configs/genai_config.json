{
  "model": {
    "type": "decoder-pipeline",
    "context_length": 128,
    "vocab_size": 100,
    "bos_token_id": 1,
    "eos_token_id": 2,
    "pad_token_id": 0,
    "decoder": {
      "component": "decoder",
      "head_size": 8,
      "hidden_size": 16,
      "num_attention_heads": 2,
      "num_hidden_layers": 1,
      "num_key_value_heads": 2,
      "pipeline": [
        { "stage_a": { "filename": "model.onnx", "inputs": ["input_ids"], "outputs": ["x"] } },
        { "stage_b": { "filename": "extra.onnx", "inputs": ["x"], "outputs": ["logits"] } }
      ]
    }
  },
  "search": { "max_length": 20 }
}
