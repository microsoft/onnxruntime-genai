{
  "model": {
    "type": "lfm2",
    "pad_token_id": 98,
    "bos_token_id": 98,
    "eos_token_id": 98,
    "vocab_size": 1000,
    "context_length": 512,
    "decoder": {
      "session_options": {
        "session.use_device_allocator_for_initializers": "0",
        "provider_options": []
      },
      "filename": "decoder.onnx",
      "num_key_value_heads": 4,
      "head_size": 8,
      "num_hidden_layers": 4,
      "layer_types": ["conv", "full_attention", "conv", "full_attention"],
      "conv_cache_size": 4,
      "inputs": {
        "past_conv_names": "past_conv.%d"
      },
      "outputs": {
        "present_conv_names": "present_conv.%d"
      }
    }
  },
  "search": {
    "past_present_share_buffer": false
  }
}
