{
  "model": {
    "type": "mistral",
    "pad_token_id": 0,
    "bos_token_id": 1,
    "eos_token_id": 2,
    "vocab_size": 256,
    "context_length": 16,
    "decoder": {
      "session_options": {
        "provider_options": []
      },
      "filename": "model.onnx",
      "num_key_value_heads": 2,
      "head_size": 16,
      "num_attention_heads": 4,
      "num_hidden_layers": 2,
      "inputs": {
        "input_ids": "input_ids",
        "position_ids": "position_ids",
        "past_key_names": "key_cache.%d",
        "past_value_names": "value_cache.%d",
        "write_indices": "write_indices",
        "nonpad_kv_seqlen": "nonpad_kv_seqlen"
      },
      "outputs": {
        "logits": "logits",
        "present_key_names": "updated_key_cache.%d",
        "present_value_names": "updated_value_cache.%d"
      }
    }
  },
  "search": {
    "max_length": 16,
    "do_sample": false
  }
}
