<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-source managed-package feed for the packaging pipeline (CFS enforced).
  All NuGet packages consumed by the packaging pipeline (ORT, build tooling,
  managed dependencies) resolve from the Lotus feed only. Non-managed binaries
  (e.g. the CUDA SDK) are fetched separately from Azure storage.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="Lotus" value="https://pkgs.dev.azure.com/aiinfra/PublicPackages/_packaging/Lotus/nuget/v3/index.json" />
  </packageSources>
</configuration>
